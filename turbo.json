{
  "$schema": "https://turbo.build/schema.json",
  "ui": "stream",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": ["dist/**", ".svelte-kit/**", "build/**"]
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "check-types": {
      "dependsOn": ["^check-types"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "db:generate": {
      "cache": false
    },
    "deploy": {
      "cache": false,
      "passThroughEnv": [
        "CI",
        "CLOUDFLARE_API_TOKEN",
        "CLOUDFLARE_ACCOUNT_ID",
        "ALCHEMY_PASSWORD",
        "BETTER_AUTH_SECRET",
        "ALCHEMY_CI_STATE_STORE_CHECK",
        "ALCHEMY_TELEMETRY_DISABLED",
        "DO_NOT_TRACK"
      ]
    },
    "destroy": {
      "cache": false
    }
  }
}
